# Unified server
HOST=127.0.0.1
PORT=9000
API_HOST=127.0.0.1
API_PORT=5001
APP_DATA_DIR=./data
REQUEST_LOGGING=true
TRACKING_CRYPTO_CACHE_TTL_MS=60000
TRACKING_CRYPTO_FAILURE_BACKOFF_MS=120000

# Model explorer upstream
MODEL_EXPLORER_SCHEME=http
MODEL_EXPLORER_HOST=127.0.0.1
MODEL_EXPLORER_PORT=8000

# Optional runtime metadata
RENDER_GIT_COMMIT=local
GITHUB_SHA=local

# Market data optional provider
ALPHA_VANTAGE_API_KEY=
US_ENABLE_ALPHA_FALLBACK=true
